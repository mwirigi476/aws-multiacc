{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAccountFullControl",
      "Effect": "Allow",
      "Principal": {"AWS": "arn:aws:iam::803871049728:root"},
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AllowS3Encryption",
      "Effect": "Allow",
      "Principal": {"Service": "s3.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:Decrypt", "kms:DescribeKey"],
      "Resource": "*"
    },
    {
      "Sid": "AllowCloudTrailEncryption",
      "Effect": "Allow",
      "Principal": {"Service": "cloudtrail.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:DescribeKey"],
      "Resource": "*"
    },
    {
      "Sid": "DenyDisableRotation",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "kms:DisableKeyRotation",
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalArn": "arn:aws:iam::803871049728:root"
        }
      }
    }
  ]
}
